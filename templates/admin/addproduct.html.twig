{% extends 'baseadmin.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .add-product-container {
            max-width: 800px;
            margin: 2rem auto;
            padding: 2.5rem;
            background: #ffffff;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
            transition: all 0.3s ease;
        }

        .add-product-title {
            text-align: center;
            margin-bottom: 2.5rem;
            font-size: 2rem;
            color: #1f2540;
            font-weight: 700;
            position: relative;
            padding-bottom: 1rem;
            border-bottom: 3px solid rgba(236, 106, 0, 0.79);
        }

        .add-product-title::after {
            content: '';
            position: absolute;
            bottom: -3px;
            left: 50%;
            transform: translateX(-50%);
            width: 80px;
            height: 3px;
            background: rgba(236, 106, 0, 0.79);
        }

        .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem;
        }

        .form-full-width {
            grid-column: 1 / -1;
        }

        .form-group {
            margin-bottom: 1.5rem;
        }

        .form-group label {
            display: block;
            margin-bottom: 0.5rem;
            font-weight: 600;
            color: #1f2540;
            font-size: 0.95rem;
        }

        .form-control {
            width: 100%;
            padding: 0.8rem 1rem;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            font-size: 1rem;
            color: #1f2540;
            background-color: #f8fafc;
            transition: all 0.3s ease;
            box-sizing: border-box;
        }

        .form-control:focus {
            outline: none;
            border-color: rgba(236, 106, 0, 0.5);
            box-shadow: 0 0 0 3px rgba(236, 106, 0, 0.1);
            background-color: #fff;
        }

        textarea.form-control {
            min-height: 120px;
            resize: vertical;
        }

        .form-error {
            color: #e53e3e;
            font-size: 0.85rem;
            margin-top: 0.5rem;
        }

        /* Image Upload */
        .image-upload-wrapper {
            position: relative;
        }

        .image-upload-wrapper input[type="file"] {
            position: absolute;
            width: 0;
            height: 0;
            opacity: 0;
        }

        .image-upload-label {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 2rem;
            background-color: #f8fafc;
            border: 2px dashed #cbd5e0;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.3s ease;
            text-align: center;
        }

        .image-upload-label:hover {
            background-color: #edf2f7;
            border-color: rgba(236, 106, 0, 0.5);
        }

        .image-upload-icon {
            font-size: 2rem;
            color: #a0aec0;
            margin-bottom: 0.5rem;
        }

        .image-upload-text {
            color: #4a5568;
            font-weight: 500;
        }

        .image-preview {
            margin-top: 1rem;
            text-align: center;
        }

        .image-preview img {
            max-width: 100%;
            max-height: 200px;
            border-radius: 8px;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
        }

        /* Submit Button */
        .btn-submit {
            width: 100%;
            padding: 1rem 2rem;
            background: linear-gradient(135deg, rgba(236, 106, 0, 0.89) 0%, rgba(255, 140, 0, 0.9) 100%);
            border: none;
            color: white;
            font-size: 1.1rem;
            font-weight: 600;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: 0 8px 15px rgba(236, 106, 0, 0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.8rem;
            position: relative;
            overflow: hidden;
            margin-top: 1.5rem;
        }

        .btn-submit:hover {
            background: linear-gradient(135deg, rgba(255, 140, 0, 0.9) 0%, rgba(236, 106, 0, 0.89) 100%);
            box-shadow: 0 12px 20px rgba(236, 106, 0, 0.4);
            transform: translateY(-3px);
        }

        .btn-submit:active {
            transform: translateY(-1px);
            box-shadow: 0 5px 10px rgba(236, 106, 0, 0.3);
        }

        .btn-submit::after {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
            transition: 0.5s;
        }

        .btn-submit:hover::after {
            left: 100%;
        }

        .btn-icon {
            transition: transform 0.3s ease;
        }

        .btn-submit:hover .btn-icon {
            transform: translateY(-2px);
        }

        /* Responsive */
        @media (max-width: 768px) {
            .add-product-container {
                padding: 1.5rem;
                margin: 1.5rem;
            }

            .add-product-title {
                font-size: 1.6rem;
                margin-bottom: 1.5rem;
            }

            .form-grid {
                grid-template-columns: 1fr;
                gap: 1rem;
            }

            .btn-submit {
                font-size: 1rem;
                padding: 0.8rem 1.5rem;
            }
        }

        @media (max-width: 480px) {
            .add-product-container {
                padding: 1.2rem;
                margin: 1rem;
            }

            .add-product-title {
                font-size: 1.4rem;
            }

            .form-group label {
                font-size: 0.9rem;
            }

            .form-control {
                padding: 0.7rem 0.9rem;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <div class="add-product-container">
        <h1 class="add-product-title">{{ is_edit ? 'Edit Product' : 'Add a New Product' }}</h1>

        {{ form_start(form, {'attr': {'class': 'product-form', 'enctype': 'multipart/form-data'}}) }}
            <div class="form-grid">
                <div class="form-group">
                    {{ form_label(form.name) }}
                    {{ form_widget(form.name, {'attr': {'class': 'form-control', 'placeholder': 'Enter product name'}}) }}
                    {% if form_errors(form.name) %}
                        <div class="form-error">{{ form_errors(form.name) }}</div>
                    {% endif %}
                </div>

                <div class="form-group">
                    {{ form_label(form.price) }}
                    {{ form_widget(form.price, {'attr': {'class': 'form-control', 'placeholder': 'Enter price in DH'}}) }}
                    {% if form_errors(form.price) %}
                        <div class="form-error">{{ form_errors(form.price) }}</div>
                    {% endif %}
                </div>

                <div class="form-group form-full-width">
                    {{ form_label(form.category) }}
                    {{ form_widget(form.category, {'attr': {'class': 'form-control'}}) }}
                    {% if form_errors(form.category) %}
                        <div class="form-error">{{ form_errors(form.category) }}</div>
                    {% endif %}
                </div>

                <div class="form-group form-full-width">
                    {{ form_label(form.description) }}
                    {{ form_widget(form.description, {'attr': {'class': 'form-control', 'placeholder': 'Enter product description'}}) }}
                    {% if form_errors(form.description) %}
                        <div class="form-error">{{ form_errors(form.description) }}</div>
                    {% endif %}
                </div>

                <div class="form-group form-full-width image-upload-wrapper">
                    {{ form_label(form.image) }}
                    <label for="{{ form.image.vars.id }}" class="image-upload-label">
                        <div class="image-upload-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
                        </div>
                        <span class="image-upload-text">Click to upload product image</span>
                    </label>
                    {{ form_widget(form.image, {'attr': {'class': 'form-control-file'}}) }}
                    {% if form_errors(form.image) %}
                        <div class="form-error">{{ form_errors(form.image) }}</div>
                    {% endif %}
                    <div class="image-preview" id="imagePreview">
                        {% if is_edit and product is defined and product.image %}
                            <img src="{{ asset('uploads/' ~ product.image) }}" alt="Product Image">
                        {% endif %}
                    </div>
                </div>
            </div>

            <button type="submit" class="btn-submit">
                {% if is_edit %}
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="btn-icon"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg>
                    Update Product
                {% else %}
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="btn-icon"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                    Add Product
                {% endif %}
            </button>
        {{ form_end(form) }}
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const imageInput = document.querySelector('input[type="file"]');
            const imagePreview = document.getElementById('imagePreview');
            
            if (imageInput) {
                imageInput.addEventListener('change', function() {
                    if (this.files && this.files[0]) {
                        const reader = new FileReader();
                        
                        reader.onload = function(e) {
                            imagePreview.innerHTML = `<img src="${e.target.result}" alt="Product Image Preview">`;
                        }
                        
                        reader.readAsDataURL(this.files[0]);
                    }
                });
            }
        });
    </script>
{% endblock %}